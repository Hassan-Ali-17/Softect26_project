generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  worker
  verifier
  advocate
}

enum VerificationStatus {
  pending
  approved
  disputed
  unverifiable
}

model User {
  id                 String   @id @default(cuid())
  email              String   @unique
  passwordHash       String
  fullName           String
  city               String
  role               UserRole @default(worker)
  isRoleApproved     Boolean  @default(false)
  isIdentityVerified Boolean  @default(false)
  createdAt          DateTime @default(now())

  shifts             Shift[]
  screenshots        Screenshot[]
  grievances         Grievance[]
}

model Shift {
  id             String   @id @default(cuid())
  userId         String
  platform       String
  shiftDate      DateTime
  hours          Float
  gross          Float
  deductions     Float
  net            Float
  cityZone       String
  createdAt      DateTime @default(now())

  user           User     @relation(fields: [userId], references: [id])
  screenshots    Screenshot[]
}

model Screenshot {
  id                 String             @id @default(cuid())
  userId             String
  shiftId            String?
  filePath           String
  verificationStatus VerificationStatus @default(pending)
  verifierComment    String?
  reviewedBy         String?
  reviewedAt         DateTime?
  createdAt          DateTime           @default(now())

  user               User               @relation(fields: [userId], references: [id])
  shift              Shift?             @relation(fields: [shiftId], references: [id])
}

model Grievance {
  id          String   @id @default(cuid())
  userId      String?
  title       String
  description String
  city        String
  platform    String
  tags        String[]
  status      String   @default("open")
  clusterKey  String?
  anonymous   Boolean  @default(true)
  createdAt   DateTime @default(now())

  user        User?    @relation(fields: [userId], references: [id])
}
